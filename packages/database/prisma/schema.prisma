generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(120)
  value     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum InventoryChangeType {
  INITIAL
  ADJUSTMENT
  RESTOCK
  STOCK_OUT
}

enum CartStatus {
  ACTIVE
  MERGED
  ABANDONED
  ORDERED
}

enum DiscountType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  COMPLETED
  CLOSED
}

enum PaymentProvider {
  TEST
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CLOSED
}

enum RefundStatus {
  REQUESTED
  PROCESSING
  SUCCEEDED
  FAILED
}

enum AfterSaleType {
  REFUND
  RETURN_REFUND
}

enum AfterSaleStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum ContactMessageStatus {
  NEW
  READ
  REPLIED
}

enum CartReminderStatus {
  PENDING
  SENT
  SKIPPED
}

enum AnalyticsEventType {
  PAGE_VIEW
  PRODUCT_VIEW
  ADD_TO_CART
  CHECKOUT_STARTED
  ORDER_CREATED
  PAYMENT_SUCCEEDED
  FAVORITE_ADDED
  NEWSLETTER_SUBSCRIBED
  CONTACT_SUBMITTED
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique @db.VarChar(180)
  name         String        @db.VarChar(120)
  passwordHash String        @map("password_hash")
  phone        String?       @db.VarChar(40)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  addresses    UserAddress[]
  sessions     UserSession[]
  carts        Cart[]
  orders       Order[]
  favorites    Favorite[]
  afterSales   AfterSaleRequest[]
  contactMessages ContactMessage[]
  behaviorEvents BehaviorEvent[]

  @@map("users")
}

model UserSession {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash") @db.VarChar(128)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model GuestSession {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  carts     Cart[]
  behaviorEvents BehaviorEvent[]

  @@index([expiresAt])
  @@map("guest_sessions")
}

model UserAddress {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  label         String   @db.VarChar(80)
  recipientName String   @map("recipient_name") @db.VarChar(120)
  phone         String   @db.VarChar(40)
  country       String   @default("CN") @db.VarChar(80)
  province      String   @db.VarChar(120)
  city          String   @db.VarChar(120)
  district      String?  @db.VarChar(120)
  line1         String   @map("line_1") @db.VarChar(240)
  postalCode    String?  @map("postal_code") @db.VarChar(40)
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_addresses")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(120)
  slug        String    @unique @db.VarChar(140)
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("categories")
}

model Product {
  id          String          @id @default(uuid()) @db.Uuid
  categoryId  String?         @map("category_id") @db.Uuid
  name        String          @db.VarChar(180)
  slug        String          @unique @db.VarChar(220)
  summary     String?
  description String
  status      ProductStatus   @default(DRAFT)
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  category    Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  options     ProductOption[]
  skus        ProductSku[]
  favorites   Favorite[]
  behaviorEvents BehaviorEvent[]

  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  url       String
  altText   String?  @map("alt_text") @db.VarChar(180)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductOption {
  id        String               @id @default(uuid()) @db.Uuid
  productId String               @map("product_id") @db.Uuid
  name      String               @db.VarChar(80)
  position  Int                  @default(0)
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]

  @@unique([productId, name])
  @@index([productId])
  @@map("product_options")
}

model ProductOptionValue {
  id       String        @id @default(uuid()) @db.Uuid
  optionId String        @map("option_id") @db.Uuid
  value    String        @db.VarChar(120)
  position Int           @default(0)
  option   ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, value])
  @@index([optionId])
  @@map("product_option_values")
}

model ProductSku {
  id                  String            @id @default(uuid()) @db.Uuid
  productId           String            @map("product_id") @db.Uuid
  skuCode             String            @unique @map("sku_code") @db.VarChar(80)
  name                String            @db.VarChar(180)
  optionSignature     Json              @map("option_signature")
  costPrice           Decimal?          @map("cost_price") @db.Decimal(12, 2)
  price               Decimal           @db.Decimal(12, 2)
  compareAtPrice      Decimal?          @map("compare_at_price") @db.Decimal(12, 2)
  weightGrams         Int?              @map("weight_grams")
  stockQuantity       Int               @default(0) @map("stock_quantity")
  lockedStockQuantity Int               @default(0) @map("locked_stock_quantity")
  lowStockThreshold   Int               @default(0) @map("low_stock_threshold")
  isActive            Boolean           @default(true) @map("is_active")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  product             Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryRecords    InventoryRecord[]
  cartItems           CartItem[]

  @@index([productId])
  @@map("product_skus")
}

model Cart {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  guestSessionId String?       @map("guest_session_id") @db.Uuid
  status         CartStatus    @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  items          CartItem[]
  orders         Order[]
  reminders      AbandonedCartReminder[]

  @@index([userId, status])
  @@index([guestSessionId, status])
  @@map("carts")
}

model CartItem {
  id                String     @id @default(uuid()) @db.Uuid
  cartId            String     @map("cart_id") @db.Uuid
  skuId             String     @map("sku_id") @db.Uuid
  quantity          Int
  unitPriceSnapshot Decimal    @map("unit_price_snapshot") @db.Decimal(12, 2)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  cart              Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  sku               ProductSku @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@unique([cartId, skuId])
  @@index([skuId])
  @@map("cart_items")
}

model ShippingTemplate {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(120)
  province              String?  @db.VarChar(120)
  baseFee               Decimal  @map("base_fee") @db.Decimal(12, 2)
  freeShippingThreshold Decimal? @map("free_shipping_threshold") @db.Decimal(12, 2)
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([province, isActive])
  @@map("shipping_templates")
}

model Coupon {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique @db.VarChar(40)
  name        String       @db.VarChar(120)
  type        DiscountType
  amount      Decimal      @db.Decimal(12, 2)
  minSubtotal Decimal      @default(0) @map("min_subtotal") @db.Decimal(12, 2)
  usageLimit  Int?         @map("usage_limit")
  usedCount   Int          @default(0) @map("used_count")
  startsAt    DateTime?    @map("starts_at")
  endsAt      DateTime?    @map("ends_at")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  orders      Order[]

  @@index([isActive])
  @@map("coupons")
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("favorites")
}

model Order {
  id             String      @id @default(uuid()) @db.Uuid
  orderNo        String      @unique @map("order_no") @db.VarChar(40)
  userId         String      @map("user_id") @db.Uuid
  cartId         String      @unique @map("cart_id") @db.Uuid
  couponId       String?     @map("coupon_id") @db.Uuid
  couponCode     String?     @map("coupon_code") @db.VarChar(40)
  status         OrderStatus @default(PENDING_PAYMENT)
  idempotencyKey String      @map("idempotency_key") @db.VarChar(120)
  addressSnapshot Json       @map("address_snapshot")
  subtotalAmount Decimal     @map("subtotal_amount") @db.Decimal(12, 2)
  shippingFee    Decimal     @map("shipping_fee") @db.Decimal(12, 2)
  discountAmount Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal     @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal?    @map("paid_amount") @db.Decimal(12, 2)
  paidCurrency   String?     @map("paid_currency") @db.VarChar(12)
  paidAt         DateTime?   @map("paid_at")
  shippedAt      DateTime?   @map("shipped_at")
  completedAt    DateTime?   @map("completed_at")
  expiresAt      DateTime    @map("expires_at")
  closedAt       DateTime?   @map("closed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  cart           Cart        @relation(fields: [cartId], references: [id], onDelete: Restrict)
  coupon         Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  payments       Payment[]
  shipment       Shipment?
  afterSales     AfterSaleRequest[]

  @@unique([userId, idempotencyKey])
  @@index([userId, status])
  @@index([status, expiresAt])
  @@map("orders")
}

model Shipment {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @unique @map("order_id") @db.Uuid
  carrierName    String   @map("carrier_name") @db.VarChar(120)
  carrierCode    String?  @map("carrier_code") @db.VarChar(80)
  trackingNumber String   @map("tracking_number") @db.VarChar(120)
  trackingUrl    String?  @map("tracking_url")
  shippedAt      DateTime @map("shipped_at")
  autoConfirmAt  DateTime @map("auto_confirm_at")
  confirmedAt    DateTime? @map("confirmed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([trackingNumber])
  @@index([autoConfirmAt])
  @@map("shipments")
}

model Payment {
  id                String            @id @default(uuid()) @db.Uuid
  orderId           String            @map("order_id") @db.Uuid
  provider          PaymentProvider
  status            PaymentStatus     @default(PENDING)
  amount            Decimal           @db.Decimal(12, 2)
  currency          String            @default("CNY") @db.VarChar(12)
  idempotencyKey    String            @map("idempotency_key") @db.VarChar(120)
  providerPaymentId String            @unique @map("provider_payment_id") @db.VarChar(120)
  checkoutUrl       String?           @map("checkout_url")
  failureReason     String?           @map("failure_reason")
  rawRequest        Json?             @map("raw_request")
  paidAt            DateTime?         @map("paid_at")
  expiresAt         DateTime?         @map("expires_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  callbacks         PaymentCallback[]
  refunds           Refund[]
  afterSaleRequests AfterSaleRequest[]

  @@unique([orderId, idempotencyKey])
  @@index([orderId, status])
  @@index([provider, status])
  @@map("payments")
}

model PaymentCallback {
  id               String          @id @default(uuid()) @db.Uuid
  paymentId        String?         @map("payment_id") @db.Uuid
  provider         PaymentProvider
  providerEventId  String          @map("provider_event_id") @db.VarChar(160)
  providerPaymentId String         @map("provider_payment_id") @db.VarChar(120)
  rawPayload       Json            @map("raw_payload")
  signature        String?         @db.VarChar(240)
  isVerified       Boolean         @default(false) @map("is_verified")
  processedAt      DateTime?       @map("processed_at")
  processingResult String?         @map("processing_result")
  createdAt        DateTime        @default(now()) @map("created_at")
  payment          Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([paymentId])
  @@index([providerPaymentId])
  @@map("payment_callbacks")
}

model Refund {
  id               String       @id @default(uuid()) @db.Uuid
  paymentId        String       @map("payment_id") @db.Uuid
  amount           Decimal      @db.Decimal(12, 2)
  currency         String       @default("CNY") @db.VarChar(12)
  status           RefundStatus @default(REQUESTED)
  reason           String?
  providerRefundId String?      @unique @map("provider_refund_id") @db.VarChar(120)
  rawResponse      Json?        @map("raw_response")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  payment          Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  afterSaleRequest AfterSaleRequest?

  @@index([paymentId, status])
  @@map("refunds")
}

model AfterSaleRequest {
  id                   String          @id @default(uuid()) @db.Uuid
  orderId              String          @map("order_id") @db.Uuid
  userId               String          @map("user_id") @db.Uuid
  paymentId            String?         @map("payment_id") @db.Uuid
  refundId             String?         @unique @map("refund_id") @db.Uuid
  type                 AfterSaleType
  status               AfterSaleStatus @default(REQUESTED)
  amount               Decimal         @db.Decimal(12, 2)
  reason               String
  returnTrackingNumber String?         @map("return_tracking_number") @db.VarChar(120)
  adminNote            String?         @map("admin_note")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  reviewedAt           DateTime?       @map("reviewed_at")
  completedAt          DateTime?       @map("completed_at")
  order                Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment              Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  refund               Refund?         @relation(fields: [refundId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([orderId])
  @@index([status, createdAt])
  @@map("after_sale_requests")
}

model NewsletterSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(180)
  source    String?  @db.VarChar(80)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("newsletter_subscriptions")
}

model ContactMessage {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String?              @map("user_id") @db.Uuid
  name      String               @db.VarChar(120)
  email     String               @db.VarChar(180)
  subject   String               @db.VarChar(180)
  message   String
  status    ContactMessageStatus @default(NEW)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  user      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("contact_messages")
}

model FaqEntry {
  id        String   @id @default(uuid()) @db.Uuid
  question  String   @db.VarChar(240)
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("faq_entries")
}

model AbandonedCartReminder {
  id        String             @id @default(uuid()) @db.Uuid
  cartId    String             @map("cart_id") @db.Uuid
  email     String?            @db.VarChar(180)
  status    CartReminderStatus @default(PENDING)
  message   String?
  scheduledAt DateTime         @map("scheduled_at")
  sentAt    DateTime?          @map("sent_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  cart      Cart               @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([cartId])
  @@map("abandoned_cart_reminders")
}

model BehaviorEvent {
  id             String             @id @default(uuid()) @db.Uuid
  userId         String?            @map("user_id") @db.Uuid
  guestSessionId String?            @map("guest_session_id") @db.Uuid
  productId      String?            @map("product_id") @db.Uuid
  anonymousId    String?            @map("anonymous_id") @db.VarChar(120)
  eventType      AnalyticsEventType @map("event_type")
  path           String             @db.VarChar(500)
  source         String?            @db.VarChar(120)
  medium         String?            @db.VarChar(120)
  campaign       String?            @db.VarChar(160)
  referrer       String?
  metadata       Json?
  occurredAt     DateTime           @default(now()) @map("occurred_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestSession   GuestSession?      @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  product        Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([eventType, occurredAt])
  @@index([userId, occurredAt])
  @@index([guestSessionId, occurredAt])
  @@index([productId, occurredAt])
  @@index([source, occurredAt])
  @@map("behavior_events")
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  skuId           String   @map("sku_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  productName     String   @map("product_name") @db.VarChar(180)
  productSlug     String   @map("product_slug") @db.VarChar(220)
  skuCode         String   @map("sku_code") @db.VarChar(80)
  skuName         String   @map("sku_name") @db.VarChar(180)
  optionSignature Json     @map("option_signature")
  imageUrl        String?  @map("image_url")
  quantity        Int
  unitPrice       Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal       Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([skuId])
  @@map("order_items")
}

model InventoryRecord {
  id          String              @id @default(uuid()) @db.Uuid
  skuId       String              @map("sku_id") @db.Uuid
  type        InventoryChangeType
  quantity    Int
  beforeStock Int                 @map("before_stock")
  afterStock  Int                 @map("after_stock")
  note        String?
  createdAt   DateTime            @default(now()) @map("created_at")
  sku         ProductSku          @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([skuId])
  @@index([createdAt])
  @@map("inventory_records")
}
